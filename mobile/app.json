{
  "expo": {
    "name": "GarlicMonkey",
    "slug": "garlicmonkey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Monkey.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Monkey.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.garlicmonkey.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Monkey.png",
        "backgroundColor": "#F9F7F2"
      },
      "package": "com.garlicmonkey.app"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "GarlicMonkey needs access to your photos to submit mission photos."
        }
      ]
    ]
  }
}
